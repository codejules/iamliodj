---
import Section from "@/layouts/Section.astro";
import BgHero from "@/components/BgHero.astro";
import Logo from "@/components/Logo.astro";
import Experience from "@/components/Experience.astro";
---

<Section class="relative h-screen">
    <BgHero />
    <Logo />
   <div
        class="h-full justify-end lg:justify-center relative flex flex-col items-start w-full px-4 md:px-10"
    >
        <div class="pt-12">
            <h1
                class="uppercase font-extrabold
         text-4xl md:text-6xl xl:text-9xl
         md:leading-[0.9] leading-10 tracking-tight
         text-white"
            >
                <span class="block">
                    La pista <br class="hidden lg:block" />
                    de baile
                </span>

                <span class="block text-gray-400 mt-2 md:mt-4">
                    no miente.
                </span>
            </h1>
        </div>
        <div class="py-10">
            <p class="text-gray-400 text-base">
                Soy Julio. DJ de Bodas y Eventos, <span class="text-white"
                    >desde 2012</span
                > haciendo que la gente no quiera irse.
            </p>
        </div>
        <Experience />
    </div>
</Section>
