---
import Section from "@/layouts/Section.astro";
---

<Section>
    <div
        class="flex flex-col items-start max-w-7xl px-10"
    >
        <div class="pt-12">
            <h1
                class="uppercase font-extrabold text-2xl md:text-6xl xl:text-9xl flex flex-col gap-20"
            >
                <span class="text-white">La pista</span>
                <span class="text-white">de baile</span>
                <span class="text-gray-400">no miente.</span>
            </h1>
            
        </div>
        <div class="pt-20">
            <p class="text-gray-400 text-xl lg:text-2xl">Soy Julio. DJ de Bodas y Eventos con <span class="text-white">más de 12 años</span> haciendo
que la gente no quiera irse.</p>
        </div>
    </div>
</Section>