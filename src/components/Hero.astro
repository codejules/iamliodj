---
import Section from "@/layouts/Section.astro";
---

<Section>
    <div
        class="md:flex md:flex-col items-start w-full lg:max-w-7xl px-4 md:px-10"
    >
        <div class="pt-12">
            <h1
                class="uppercase font-extrabold
         text-4xl md:text-7xl xl:text-9xl
         md:leading-[0.9] leading-10 tracking-tight
         text-white"
            >
                <span class="block">
                    La pista <br class="hidden lg:block" />
                    de baile
                </span>

                <span class="block text-gray-400 mt-2 md:mt-4">
                    no miente.
                </span>
            </h1>
        </div>
        <div class="pt-10 md:pt-20">
            <p class="text-gray-400 text-base">
                Soy Julio. DJ de Bodas y Eventos con <span class="text-white"
                    >más de 12 años</span
                > haciendo que la gente no quiera irse.
            </p>
        </div>
    </div>
</Section>
